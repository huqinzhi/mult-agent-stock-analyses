# MiniMax 配置
MINIMAX_API_KEY=xxxx
MINIMAX_BASE_URL=xxxx
MINIMAX_MODEL=MiniMax-M2.7

# 通知渠道配置
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx

# 调度配置
SCHEDULER_ENABLED=true
SCHEDULER_TIME=10:00

# ───────────────────────────────────────
# Agent 权重模式（重要）
# ───────────────────────────────────────
# 权重模式：fixed=固定权重（读取下方配置），auto=Supervisor 动态分配
WEIGHT_MODE=auto

# 固定权重配置（WEIGHT_MODE=fixed 时生效，各 Agent 权重总和必须 = 1.0）
WEIGHT_QUANTITATIVE=0.25
WEIGHT_CHART=0.15
WEIGHT_INTELLIGENCE=0.10
WEIGHT_RISK=0.20
WEIGHT_FUNDAMENTAL=0.20
WEIGHT_SENTIMENT=0.10

# ───────────────────────────────────────
# 批量分析配置
# ───────────────────────────────────────
# 批量分析时是否仅输出评分前N名（默认开启）
BATCH_TOP_N_ENABLED=true
# 前N名的数量
BATCH_TOP_N_COUNT=5
